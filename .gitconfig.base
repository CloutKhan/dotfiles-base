# https://git-scm.com/docs/git-config # For git's docs on config
# To understand how this works and why we use "base/init/apply", read
# https://github.com/Skenvy/dotfiles/blob/main/git/README.md
# And see the two apply scripts that facilitate this;
# https://github.com/Skenvy/dotfiles/blob/main/git/config/apply.sh
# https://github.com/Skenvy/dotfiles/blob/main/git/config/apply.ps1

[include]
    path = .include/.pre/.gitconfig

[core]
    # autocrlf = <add in .include/.pre/.gitconfig>
    # editor = <add in .include/.pre/.gitconfig>
    # filemode = <add in .include/.pre/.gitconfig>
    # symlinks = <add in .include/.pre/.gitconfig>

[gpg]
    # program = <add in .include/.pre/.gitconfig>

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[pull]
    ff = only

[user]
    # email = <add in .include/.post/.gitconfig>
    # name = <add in .include/.post/.gitconfig>
    # signingkey = <add in .include/.post/.gitconfig>

[commit]
    # gpgsign = <add in .include/.post/.gitconfig>

[tag]
    # gpgSign = <add in .include/.post/.gitconfig>

[include]
    path = .include/.post/.gitconfig
